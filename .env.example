# =============================================================================
# Finca Danilandia — Environment Variables
# Copy to .env.local and fill in values
# =============================================================================

# Supabase (current key system — legacy anon/service_role are deprecated)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Publishable key (client-safe). Replaces the legacy anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Secret key (SERVER ONLY — never expose). Replaces the legacy service_role key.
SUPABASE_SECRET_KEY=sb_secret_...

# Database (Supabase PostgreSQL)
# Connection pooler (for Prisma Client in serverless)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (for Prisma Migrate)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Claude AI (para extracción de fotos de cuaderno)
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
