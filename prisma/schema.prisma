// =============================================================================
// Finca Danilandia y Anexos, S.A. — Database Schema
// Part of Holding Grupo Orión
// Agricultural Year: March → February
// Currency: Quetzales (GTQ)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// AUTH & ACCESS
// =============================================================================

enum UserRole {
  MASTER // You — full CRUD, all settings, user management
  ADMIN // Luis — full CRUD, payroll, data entry, settings
  MANAGER // Roberto — read-all, approve payroll, dashboards
  FIELD // Caporal — mobile data entry (activities, intake)
  CEO // Octavio — dashboard only (future)
  CFO // José — read-all, no updates (financial oversight)
  CONSULTANT // External — read-all, no writes
}

model User {
  id         String   @id @default(uuid(7)) @db.Uuid
  supabaseId String   @unique @map("supabase_id")
  email      String   @unique
  name       String
  role       UserRole @default(FIELD)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  auditLogs AuditLog[]

  @@map("users")
}

// =============================================================================
// SYSTEM SETTINGS
// =============================================================================

model SystemSetting {
  id        String   @id @default(uuid(7)) @db.Uuid
  key       String   @unique // "pay_period_type", "agricultural_year_start_month", etc.
  value     String // JSON-encoded value
  label     String // Human-readable label: "Tipo de período de pago"
  group     String // Grouping: "payroll", "general", "alerts"
  updatedBy String?  @map("updated_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@map("system_settings")
}

// =============================================================================
// FINCA STRUCTURE
// =============================================================================

model Lote {
  id           String   @id @default(uuid(7)) @db.Uuid
  name         String   @unique
  slug         String   @unique
  areaManzanas Decimal? @map("area_manzanas") @db.Decimal(8, 2)
  plantCount   Int?     @map("plant_count")
  density      String?
  altitudeMasl Int?     @map("altitude_masl")
  variety      String?
  podaPercent  Decimal? @map("poda_percent") @db.Decimal(5, 2)
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  activityRecords     ActivityRecord[]
  coffeeIntakes       CoffeeIntake[]
  planEntries         PlanEntry[]
  productionEstimates ProductionEstimate[]

  @@map("lotes")
}

// =============================================================================
// WORKERS
// =============================================================================

// Canonical worker identity. Person fields use DPI canon names verbatim
// (DPI_Finca.csv): `apellidos` = both surnames combined, `nombres` = given
// names combined — NEVER split. `cui` is the national ID captured verbatim
// (modern 13-digit OR legacy formats); it is the unique identity key.
// `fullName` is a maintained display value (= "nombres apellidos"), kept so
// display/back-compat code need not all change at once.
model Worker {
  id        String @id @default(uuid(7)) @db.Uuid
  cui       String @unique
  apellidos String
  nombres   String
  fullName  String @map("full_name")

  // Canonical person attributes (DPI canon; golden record)
  fechaNacimiento      DateTime? @map("fecha_nacimiento") @db.Date
  sexo                 String?
  nacionalidad         String?
  lugarNacimiento      String?   @map("lugar_nacimiento")
  vecindad             String?
  pueblo               String?
  comunidadLinguistica String?   @map("comunidad_linguistica")
  estadoCivil          String?   @map("estado_civil")
  personPhotoUrl       String?   @map("person_photo_url")

  // App-managed (not from SSOT): payroll banking, lifecycle
  nit         String?
  bankAccount String?        @map("bank_account")
  bankName    String?        @map("bank_name")
  phone       String?
  // Payroll classification — current, toggleable on the worker config page
  // (not permanent). Recompute snapshots this into the period's payroll_entry.
  category    WorkerCategory @default(VOLUNTARIO)
  isMinor     Boolean        @default(false) @map("is_minor")
  isActive    Boolean        @default(true) @map("is_active")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  documents       WorkerDocument[]
  activityRecords ActivityRecord[]
  payrollEntries  PayrollEntry[]

  @@map("workers")
}

enum DocumentType {
  DPI
  BIRTH_CERTIFICATE
}

// Shared parent (supertype) for identity documents. One-to-many from Worker;
// a person may hold a DPI and a birth certificate (one of each).
model WorkerDocument {
  id                   String       @id @default(uuid(7)) @db.Uuid
  workerId             String       @map("worker_id") @db.Uuid
  type                 DocumentType
  cuiAsPrinted         String?      @map("cui_as_printed")
  extractionConfidence Decimal?     @map("extraction_confidence") @db.Decimal(5, 2)
  notes                String?
  sourceFile           String?      @map("source_file")
  sourcePage           Int?         @map("source_page")
  importedAt           DateTime     @default(now()) @map("imported_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  worker           Worker                    @relation(fields: [workerId], references: [id])
  dpi              DpiDocument?
  birthCertificate BirthCertificateDocument?

  @@unique([workerId, type])
  @@index([workerId])
  @@map("worker_documents")
}

// DPI child (1:1, shared PK). Holds the DPI-card specifics + as-stated values
// (provenance — what THIS card said, vs the worker's golden values).
model DpiDocument {
  documentId       String    @id @map("document_id") @db.Uuid
  fechaVencimiento DateTime? @map("fecha_vencimiento") @db.Date
  frontImageUrl    String?   @map("front_image_url")
  backImageUrl     String?   @map("back_image_url")
  apellidos            String?
  nombres              String?
  fechaNacimiento      DateTime? @map("fecha_nacimiento") @db.Date
  sexo                 String?
  nacionalidad         String?
  lugarNacimiento      String?   @map("lugar_nacimiento")
  vecindad             String?
  pueblo               String?
  comunidadLinguistica String?   @map("comunidad_linguistica")
  estadoCivil          String?   @map("estado_civil")

  document WorkerDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("dpi_documents")
}

// Birth-certificate child (1:1, shared PK). Inscrito as-stated + parents
// (provenance only; parents are not workers). Parent DOB/CUI kept as text —
// old records carry partial/legacy values; capture verbatim, never coerce.
model BirthCertificateDocument {
  documentId              String    @id @map("document_id") @db.Uuid
  correlativo             String?
  fechaEmisionCertificado DateTime? @map("fecha_emision_certificado") @db.Date
  imageUrl                String?   @map("image_url")
  inscritoFechaNacimiento DateTime? @map("inscrito_fecha_nacimiento") @db.Date
  inscritoLugarNacimiento String?   @map("inscrito_lugar_nacimiento")
  inscritoSexo            String?   @map("inscrito_sexo")
  madreNombresApellidos   String?   @map("madre_nombres_apellidos")
  madreCui                String?   @map("madre_cui")
  madreFechaNacimiento    String?   @map("madre_fecha_nacimiento")
  madreLugarOrigen        String?   @map("madre_lugar_origen")
  padreNombresApellidos   String?   @map("padre_nombres_apellidos")
  padreCui                String?   @map("padre_cui")
  padreFechaNacimiento    String?   @map("padre_fecha_nacimiento")
  padreLugarOrigen        String?   @map("padre_lugar_origen")

  document WorkerDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("birth_certificate_documents")
}

// =============================================================================
// ACTIVITY CATALOG
// =============================================================================

enum ActivityUnit {
  QUINTAL // qq
  MANZANA // mz
  HECTAREA // ha
  DIA // día trabajado
}

model Activity {
  id           String       @id @default(uuid(7)) @db.Uuid
  name         String       @unique
  code         String?      @unique // farm shorthand (CP, BE, MG, RP…) from ACTIVIDADES
  unit         ActivityUnit
  defaultPrice Decimal?     @map("default_price") @db.Decimal(10, 2)
  isHarvest    Boolean      @default(false) @map("is_harvest")
  isBeneficio  Boolean      @default(false) @map("is_beneficio")
  sortOrder    Int          @default(0) @map("sort_order")
  isActive     Boolean      @default(true) @map("is_active")
  description  String?      @map("description")
  minQtyAlert  Decimal?     @map("min_qty_alert") @db.Decimal(10, 2)
  maxQtyAlert  Decimal?     @map("max_qty_alert") @db.Decimal(10, 2)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  activityRecords ActivityRecord[]
  planEntries     PlanEntry[]
  prices          ActivityPrice[]

  @@map("activities")
}

// Effective-dated price history for an activity. The price applied to a work
// record is the one whose effectiveFrom is the latest <= the record's work date
// (see src/lib/pricing/resolve-price.ts). Activity.defaultPrice is kept as the
// denormalized "current" price for display and as a fallback for dates before
// any vigencia. Past ActivityRecord.unitPrice values are snapshots and never
// change — so price edits have no retroactive effect.
model ActivityPrice {
  id            String   @id @default(uuid(7)) @db.Uuid
  activityId    String   @map("activity_id") @db.Uuid
  price         Decimal  @db.Decimal(10, 2)
  effectiveFrom DateTime @map("effective_from") @db.Date
  note          String?
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, effectiveFrom])
  @@index([activityId, effectiveFrom])
  @@map("activity_prices")
}

// =============================================================================
// MODULE 1: PLANILLA
// =============================================================================

enum PayPeriodType {
  SEMANAL
  CATORCENA
}

model PayPeriod {
  id               String        @id @default(uuid(7)) @db.Uuid
  type             PayPeriodType @default(SEMANAL)
  periodNumber     Int           @map("period_number")
  agriculturalYear String        @map("agricultural_year") // "2526"
  startDate        DateTime      @map("start_date") @db.Date
  endDate          DateTime      @map("end_date") @db.Date
  isClosed         Boolean       @default(false) @map("is_closed")
  closedAt         DateTime?     @map("closed_at")
  closedBy         String?       @map("closed_by") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  activityRecords ActivityRecord[]
  payrollEntries  PayrollEntry[]

  @@unique([agriculturalYear, periodNumber, type])
  @@map("pay_periods")
}

model ActivityRecord {
  id          String    @id @default(uuid(7)) @db.Uuid
  date        DateTime  @db.Date
  payPeriodId String    @map("pay_period_id") @db.Uuid
  workerId    String    @map("worker_id") @db.Uuid
  activityId  String    @map("activity_id") @db.Uuid
  loteId      String?   @map("lote_id") @db.Uuid
  quantity    Decimal   @db.Decimal(10, 2)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(10, 2)
  totalEarned Decimal   @map("total_earned") @db.Decimal(10, 2)
  notes       String?
  clientId    String?   @unique @map("client_id") // Offline sync dedup key
  syncedAt    DateTime? @map("synced_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  payPeriod PayPeriod @relation(fields: [payPeriodId], references: [id])
  worker    Worker    @relation(fields: [workerId], references: [id])
  activity  Activity  @relation(fields: [activityId], references: [id])
  lote      Lote?     @relation(fields: [loteId], references: [id])

  @@index([date])
  @@index([payPeriodId])
  @@index([workerId])
  @@index([loteId])
  @@index([activityId])
  @@map("activity_records")
}

model PayrollEntry {
  id           String          @id @default(uuid(7)) @db.Uuid
  payPeriodId  String          @map("pay_period_id") @db.Uuid
  workerId     String          @map("worker_id") @db.Uuid
  category     WorkerCategory  @default(VOLUNTARIO)
  totalEarned   Decimal         @map("total_earned") @db.Decimal(10, 2)
  bonification  Decimal         @default(0) @db.Decimal(10, 2)
  seventhDayPay Decimal         @default(0) @map("seventh_day_pay") @db.Decimal(10, 2)
  advances     Decimal         @default(0) @db.Decimal(10, 2)
  deductions   Decimal         @default(0) @db.Decimal(10, 2)
  // Audit notes (CFO requirement): required when the matching amount is non-zero.
  bonificationNote String?     @map("bonification_note")
  deductionsNote   String?     @map("deductions_note")
  totalToPay   Decimal         @map("total_to_pay") @db.Decimal(10, 2)
  isPaid       Boolean         @default(false) @map("is_paid")
  paidAt       DateTime?       @map("paid_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  payPeriod PayPeriod @relation(fields: [payPeriodId], references: [id])
  worker    Worker    @relation(fields: [workerId], references: [id])

  @@unique([payPeriodId, workerId, category])
  @@map("payroll_entries")
}

enum WorkerCategory {
  VOLUNTARIO
  FIJO
}

// Official / non-working days. Read by the séptimo computation to reduce the
// number of required workdays in a week (required = 6 − holidays that week).
// New table → UUIDv7 per project conventions (existing tables remain v4 until
// the separate rebuild migration).
model Holiday {
  id              String   @id @default(uuid(7)) @db.Uuid
  date            DateTime @unique @db.Date
  name            String
  recurringAnnual Boolean  @default(false) @map("recurring_annual")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("holidays")
}

// =============================================================================
// MODULE 2: INGRESO DE CAFÉ
// =============================================================================

enum CoffeeType {
  CEREZA
  PERGAMINO
  ORO
}

enum IntakeSource {
  COSECHA
  COMPRA
}

enum CoffeeStatus {
  RECIBIDO
  DESPULPADO
  SECANDO
  PERGAMINO
  ENVASADO
  DESPACHADO
}

model CoffeeIntake {
  id              String       @id @default(uuid(7)) @db.Uuid
  code            String       @unique
  date            DateTime     @db.Date
  coffeeType      CoffeeType   @default(CEREZA) @map("coffee_type")
  source          IntakeSource @default(COSECHA)
  loteId          String?      @map("lote_id") @db.Uuid
  supplierName    String?      @map("supplier_name")
  procedencia     String? // Origin location for COMPRA
  supplierAccount String?      @map("supplier_account") // Bank account for payment
  pricePerQq      Decimal?     @map("price_per_qq") @db.Decimal(10, 2) // Purchase price per quintal
  paymentStatus   String?      @map("payment_status") // "CANCELADO", "PENDIENTE"
  bultos          Int?
  pesoNetoQq      Decimal      @map("peso_neto_qq") @db.Decimal(10, 2)
  pesoVerdeQq     Decimal?     @map("peso_verde_qq") @db.Decimal(10, 2)
  pesoPergaminoQq Decimal?     @map("peso_pergamino_qq") @db.Decimal(10, 2)
  rendimiento     Decimal?     @db.Decimal(6, 2)
  status          CoffeeStatus @default(RECIBIDO)
  processedDate   DateTime?    @map("processed_date") @db.Date
  dispatchDate    DateTime?    @map("dispatch_date") @db.Date
  dispatchCode    String?      @map("dispatch_code")
  cuppingScore    Decimal?     @map("cupping_score") @db.Decimal(4, 1)
  notes           String?
  clientId        String?      @unique @map("client_id")
  syncedAt        DateTime?    @map("synced_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  lote Lote? @relation(fields: [loteId], references: [id])

  @@index([date])
  @@index([loteId])
  @@index([status])
  @@map("coffee_intakes")
}

// =============================================================================
// MODULE 3: ACTIVITY PLANNING
// =============================================================================

model PlanEntry {
  id               String   @id @default(uuid(7)) @db.Uuid
  agriculturalYear String   @map("agricultural_year")
  loteId           String   @map("lote_id") @db.Uuid
  activityId       String   @map("activity_id") @db.Uuid
  month            Int
  week             Int
  plannedJornales  Decimal  @map("planned_jornales") @db.Decimal(8, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  lote     Lote     @relation(fields: [loteId], references: [id])
  activity Activity @relation(fields: [activityId], references: [id])

  @@unique([agriculturalYear, loteId, activityId, month, week])
  @@index([agriculturalYear])
  @@map("plan_entries")
}

// =============================================================================
// MODULE 4: PRODUCTION ESTIMATES
// =============================================================================

enum EstimateType {
  PRIMERA
  SEGUNDA
  TERCERA
  CUARTA
  FINAL
}

model ProductionEstimate {
  id               String       @id @default(uuid(7)) @db.Uuid
  agriculturalYear String       @map("agricultural_year")
  loteId           String       @map("lote_id") @db.Uuid
  estimateType     EstimateType @map("estimate_type")
  estimateDate     DateTime     @map("estimate_date") @db.Date
  lbPerPlant       Decimal      @map("lb_per_plant") @db.Decimal(6, 2)
  qqMaduroPerLote  Decimal?     @map("qq_maduro_per_lote") @db.Decimal(10, 2)
  qqOroPerManzana  Decimal?     @map("qq_oro_per_manzana") @db.Decimal(10, 2)
  qqOroPerLote     Decimal?     @map("qq_oro_per_lote") @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  lote Lote @relation(fields: [loteId], references: [id])

  @@unique([agriculturalYear, loteId, estimateType])
  @@index([agriculturalYear])
  @@map("production_estimates")
}

// =============================================================================
// AUDIT
// =============================================================================

model AuditLog {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String
  tableName String   @map("table_name")
  recordId  String   @map("record_id")
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
